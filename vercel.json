{
  "version": 2,
  "framework": "nextjs",
  "regions": ["cle1"],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(fonts|images|icons)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
